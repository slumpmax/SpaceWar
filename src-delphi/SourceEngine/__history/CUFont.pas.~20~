constructor TCUFont.Create(AGL: TXPGL);
var
  nx, ny, px, py: Integer;
  vptr: PColor32Array;
  b: Byte;
begin
  FBitmap := TXPBitmap.Create;
  FBitmap.Width := 256;
  FBitmap.Height := 140;
  FColor := c32White;
  for ny := 0 to 6 do
  begin
    for nx := 0 to 31 do
    begin
      for py := 0 to 19 do
      begin
        b := FFontTable[32 + ny * 32 + nx][py];
        vptr := FBitmap.ScanLine[ny * 20 + py];
        for px := 0 to 7 do
        begin
          if (b and ($80 shr px)) > 0 then
            vptr[nx * 8 + px] := Color32($FFFFFFFF)
          else vptr[nx * 8 + px] := c32Clear;
        end;
      end;
    end;
  end;
  if AGL <> nil then
  begin
    FTexture := TXPTexture.Create(AGL);
    FTexture.BlendSrc := GL_SRC_ALPHA;
    FTexture.MinFilter := GL_NEAREST;
    FTexture.MagFilter := GL_NEAREST;
    FTexture.LoadFromXPBitmap(FBitmap);
  end
  else FTexture := nil;
end;

destructor TCUFont.Destroy;
begin
  FBitmap.Free;
  FTexture.Free;
  inherited Destroy;
end;

function TCUFont.GetColor: TColor32;
begin
  if FTexture <> nil then
  begin
    Result.R := Round(FTexture.Color.R * 255);
    Result.G := Round(FTexture.Color.G * 255);
    Result.B := Round(FTexture.Color.B * 255);
    Result.A := Round(FTexture.Color.A * 255);
  end
  else Result := FColor;
end;

function TCUFont.GetColorFloat: TGLRGBAFloat;
begin
  if FTexture <> nil then
    Result := FTexture.Color
  else
  begin
    Result.R := FColor.R / 255;
    Result.G := FColor.G / 255;
    Result.B := FColor.B / 255;
    Result.A := FColor.A / 255;
  end;
end;

procedure TCUFont.SetColor(const Value: TColor32);
begin
  FColor := Value;
  if Assigned(FTexture) then
  begin
    FTexture.Color.R := Value.R / 255;
    FTexture.Color.G := Value.G / 255;
    FTexture.Color.B := Value.B / 255;
    FTexture.Color.A := Value.A / 255;
  end;
end;

procedure TCUFont.SetColorFloat(const Value: TGLRGBAFloat);
begin
  FColor.R := Round(Value.R * 255);
  FColor.G := Round(Value.G * 255);
  FColor.B := Round(Value.B * 255);
  FColor.A := Round(Value.A * 255);
  if Assigned(FTexture) then FTexture.Color := Value;
end;

function TCUFont.TextWidth(AText: AnsiString): Integer;
var
  n: Integer;
begin
  Result := 0;
  for n := 1 to Length(AText) do
  begin
    if Pos(AText[n], NoWidthChar) = 0 then Result := Result + 8;
  end;
end;


  Outputs: AnsiString = #$A1#$A2#$A3#$A4#$A5#$A6#$A7#$A8#$A9#$AA
    + #$AB#$AC#$AD#$AE#$AF#$B0#$B1#$B2#$B3#$B4
    + #$B5#$B6#$B7#$B8#$B9#$BA#$BB#$BC#$BD#$BE
    + #$BF#$C0#$C1#$C2#$C3#$C4#$C5#$C6#$C7#$C8
    + #$C9#$CA#$CB#$CC#$CD#$CE
    + #$D4#$D5#$D6#$D7#$D8#$D9#$DA
    + #$D0#$D1#$D2#$D3#$D4#$D5#$D6#$D7
    + #$E8#$E9#$EA#$EB#$EC#$ED#$EE;
var
  p, n: Integer;
  ch: Char;
begin
  Result := '';
  for n := 1 to Length(AText) do
  begin
    ch := AText[n];
    p := Pos(ch, Inputs);
    if p > 0 then
      Result := Result + Outputs[p]
    else Result := Result + AnsiChar(ch);
  end;
end;


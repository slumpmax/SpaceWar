// print text thai by CU font
procedure TCUFont.TextOut(gbm: TXPBitmap; px, py: Integer; AText: string);
var
  ch, bh: AnsiChar;
  cx, cy, p: Integer;
  s: AnsiString;
begin
  s := TextDecode(AText);
  bh := #0;
  while Length(s) > 0 do
  begin
    ch := s[1];
    Delete(s, 1, 1);
  	if ch > #32 then
    begin
	    if ch = #$D3 then
      begin
        CharOut(gbm, px - 8, py, AnsiChar($ED));
        CharOut(gbm, px, py, AnsiChar(Ord(ch) - 1));
      end
      else
      begin
        if Pos(ch, NoWidthChar) > 0 then px := px - 8;
        cx := px;
        cy := py;
        if (ch >= #$E7) and (ch <= #$EC) then
        begin
          if Copy(s, 1, 1) = #$D3 then bh := #$D3;
          p := Pos(bh, NoWidthChar);
          if (p = 0) or (p > 7) then
          begin
            cx := px;
            cy := py + 4;
          end;
        end;
  	    CharOut(gbm, cx, cy, AnsiChar(ch));
      end;
    end;
  	px := px + 8;
    bh := ch;
  end;
end;

procedure TCUFont.TextOut(gbm: TXPBitmap; drect: TRect; AText: string);
var
  ch, cb: AnsiChar;
  px, py, cx, cy, p, n, wt, ht, wd, hd: Integer;
  srect: TRect;
  s: AnsiString;
begin
  s := TextDecode(AText);
  wt := TextWidth(s);
  ht := TextHeight(s);
  wd := drect.Right - drect.Left;
  hd := drect.Bottom - drect.Top;
  px := 0;
  py := 0;
  cb := #0;
  n := 0;
  while n < Length(s) do
  begin
    Inc(n);
    ch := s[n];
  	if ch > #32 then
    begin
	    if ch = #$D3 then
      begin
        srect.Left := drect.Left + (px - 8) * wd div wt;
        srect.Top := drect.Top + py * hd div ht;
        srect.Right := drect.Left + px * wd div wt;
        srect.Bottom := drect.Top + (py + 20) * hd div ht;
        CharOut(gbm, srect, AnsiChar($ED));
        srect.Left := srect.Right;
        srect.Right := drect.Left + (px + 8) * wd div wt;
        CharOut(gbm, srect, AnsiChar(Ord(ch) - 1));
      end
      else
      begin
        if Pos(ch, NoWidthChar) > 0 then px := px - 8;
        cx := px;
        cy := py;
        if (ch >= #$E7) and (ch <= #$EC) then
        begin
          if Copy(s, n + 1, 1) = #$D3 then cb := #$D3;
          p := Pos(cb, NoWidthChar);
          if (p = 0) or (p > 7) then
          begin
            cx := px;
            cy := py + 4;
          end;
        end;
        srect.Left := drect.Left + cx * wd div wt;
        srect.Top := drect.Top + cy * hd div ht;
        srect.Right := drect.Left + (cx + 8) * wd div wt;
        srect.Bottom := drect.Top + (cy + 20) * hd div ht;
  	    CharOut(gbm, srect, AnsiChar(ch));
      end;
    end;
  	px := px + 8;
    cb := ch;
  end;
end;

procedure TCUFont.GLCharOut(px, py: Integer; AChar: AnsiChar);

  if AChar > #32 then
  begin
    Dec(AChar, 32);
    FBitmap.ClipRect := Bounds((Byte(AChar) and $1F) shl 3, (Byte(AChar) shr 5) * 20, 8, 20);
    gbm.Draw(px, py, FBitmap, xdmMono);
  end;
end;


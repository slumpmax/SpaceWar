  GRocket2.Free;
  GMyGun.Free;
  for n := 0 to 15 do GEnemySprite[n].Free;
  MainKey.Free;
  MainFont.Free;
  MainSprite.Free;
  FrameRate.Free;
  MainTime.Free;
  MainGL.Free;
end;

procedure TMainForm.FormKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  case Key of
    VK_F1:
    begin
      if (WindowState = wsMaximized) and (BorderStyle = bsNone) then
      begin
        BorderStyle := bsSizeable;
        WindowState := wsNormal;
        Cursor := crDefault;
      end
      else
      begin
        BorderStyle := bsNone;
        WindowState := wsMaximized;
        Cursor := crNone;
      end;
    end;
    VK_F2: ShowFPS := not ShowFPS;
    VK_ESCAPE: Close;
  else
    MainKey.Update(Key, True);
  end;
  Key := 0;
end;

procedure TMainForm.FormKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  MainKey.Update(Key, False);
  Key := 0;
end;

procedure TMainForm.InitState;
begin
  EnemyIndex := 0;
  EnemyDelay := 200;
  Power := 10;
end;

procedure TMainForm.UpdateScreen(Updated: Boolean = True);
var
  n: Integer;
begin
  if not Assigned(MainGL) then Exit;
  
  MainGL.Activate;
  MainGL.Clear;
  Retrace := MainTime.OneCount and Updated;

  MainGL.DrawRight := ScaleX(XSCreen);
  MainGL.BrushColor := c32Black;
  MainGL.FillRect;
  MainGL.BrushColor := Color32($FF000065);
  MainGL.FillRect(ScaleRect(260, 0, 360, 240));

  if Stage < 1 then
    n := 1
  else if Stage > 3 then
    n := 3
  else n := Stage;
  PutText(290, 10, 'ฉาก', Color32($FF309AFF));
  PutNumber(320, 10, n, Color32($FF00CB30));
  PutText(290, 30, 'คะแนน', Color32($FF309AFF));
  PutNumber(268, 47, Score, Color32($FF00CB30), 10);
  PutText(270, 70, 'ระเบิด:', Color32($FF309AFF));
  PutNumber(320, 70, Bomb, Color32($FF00CB30), 2);
  PutText(280, 110, 'พลังงาน', Color32($FF309AFF));
  PutText(310, 170, 'x', Color32($FF309AFF));
  PutNumber(324, 170, Life, Color32($FF00CB30), 2);
  GPutSprite(280, 170, GRocket1);
  ShowPow;
  MainGL.DrawRight := ScaleX(XMax);
  PutStar;
  if Started then
  begin
    InitState;
    TitleDelay := 200;
    Started := False;
  end
  else
  begin
    if (TitleDelay <> 0) and (Stage > 0) and (Stage < 4) then
    begin
      if Retrace then Dec(TitleDelay);
      if TitleDelay <> 0 then
      begin
        PutText(48, 70, Format('ฉาก %d สู้ตายเพื่อท่านปึ๋ย!', [Stage]), Color32($FF30CB00));
      end;
    end;
    if Stage = 0 then
    begin
      PutText(30, 50, 'CTRL:ยิง ALT:ระเบิด ESC:ออก', Color32($FF30CB00));
      PutText(55, 70, 'F1:เต็มจอ F2:เฟรมเรต', Color32($FF30CB00));
      PutText(55, 150, 'กดอะไรก็ได้เพื่อเริ่มเกมส์', Color32($FF30CB00));
      if MainKey.LastKeyDown <> 0 then Inc(Stage);
    end
    else if Stage > 3 then
    begin
      PutText(35, 70, 'ดูเด่ะ เล่นมาตั้งนาน จบเฉยเลย', Color32($FF30CB00));
      PutText(18, 95, 'โปรแกรมโดย เชษฐา เจนจิโรจพิพัฒน์', Color32($FF30CB00));
      PutText(28, 120, 'Windows Engine by SLUMPMAX', Color32($FF3000CB));
    end
    else if PutEnemy then if PassGame then Started := True;
    if (Life > 0) then
    begin
      PutRocket;
      Gun;
      Toom;
    end
    else
    begin
      YRocket := 240;
      PutText(28, 70, 'นักรบพลีชีพหมดแล้ว ท่านปึ๋ยจงเจริญ!', Color32($FF30CB00));
      PutText(18, 95, 'โปรแกรมโดย เชษฐา เจนจิโรจพิพัฒน์', Color32($FF30CB00));
      PutText(28, 120, 'Windows Engine by SLUMPMAX', Color32($FF3000CB));
    end;
  end;
  if ShowFPS then
  begin
    PutText(10, 10, Format('Frame Rate: %.2f FPS', [FrameRate.Update]), c32White);
  end;
  MainGL.SwapBuffer;
end;

procedure TMainForm.FormResize(Sender: TObject);
begin
  MainGL.SetBounds(Rect(0, 0, ClientWidth, ClientHeight));
  UpdateScreen(False);
end;

procedure TMainForm.WMEraseBkgnd(var msg: TWMEraseBkgnd);
begin
  msg.Result := 1;
end;

procedure TMainForm.MainAppEventsIdle(Sender: TObject;
  var Done: Boolean);
begin

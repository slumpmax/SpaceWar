  Done := False;
end;

// draw black ground star
procedure TMainForm.PutStar;
var
  i, j, p, n: Integer;
begin
  i := 0;
  n := 0;
  while i < 240 do
  begin
    j := i + YStar;
  	if j > 241 then j := j - 242;
  	if j = 0 then CStar[n] := Random(260);
  	p := CStar[n];
    Inc(n);
  	if j < 240 then
    begin
      MainGL.BrushColor := Color32($FF659ACB);
      MainGL.FillRect(ScaleRect(p, j, 1, 1));
    end;
    Inc(i, 12);
  end;
  if Retrace then
  begin
    Inc(YStar);
    if YStar > 241 then YStar := YStar - 242;
  end;
end;

// Show power
procedure TMainForm.ShowPow;
var
  n: Integer;
begin
  MainGL.BrushColor := c32Black;
  MainGL.FillRect(ScaleRect(284, 132, 43, 6));

  MainGL.BrushColor := Color32($FFFFFF65);
  n := Power;
  if n > 10 then n := 10;
  while n >= 0 do
  begin
    MainGL.FillRect(ScaleRect(284 + n * 4, 132, 3, 6));
    Dec(n);
  end;
end;

// draw my rocket
procedure TMainForm.PutRocket;
const
  k: Integer = 0; // variable for swap rocket picture
  m: Integer = 0; // variable for start rocket
  b: Integer = 100; // boom
begin
  if Damage = 200 then
  begin
    PInt(@m)^ := 70;
    Power := 11;
  end;
  if ((Power < 0) or (YRocket > 212)) and (m = 0) then
  begin
  	Power := -1;
    if Retrace or not Boom then
    begin
      XBoom := XRocket + Random(30) - 10;
      YBoom := YRocket + Random(30) - 10;
      Boom := True;
    end;
  	GPutSprite(XBoom, YBoom, GEnemySprite[13]);
    if Retrace then
    begin
      Dec(PInt(@b)^);
    	if b = 0 then
      begin
        PInt(@b)^ := 100;
        Damage := 201;
        Dec(Life);
        Boom := False;
      end;
    end;
  end
  else
  begin
  	XOld := XRocket;
    YOld := YRocket;
  	if m <> 0 then
    begin
      XRocket := 110;
      YRocket := m * 2 + 100;
    end;
    if Retrace then
    begin
      if m <> 0 then Dec(PInt(@m)^);
      XRocket := XRocket + (MainKey[VK_RIGHT] - MainKey[VK_LEFT]) * 3;
      YRocket := YRocket + (MainKey[VK_DOWN] - MainKey[VK_UP]) * 3;
	    if OutsideInt(XRocket, 0, 233) then XRocket := XOld;
 	    if OutsideInt(YRocket, 0, 212) then YRocket := YOld;
    end;
  	if (DaMage and 3) = 1 then
    begin
      if (k and 4) > 0 then
        GPutSprite(XRocket, YRocket, GRocketB1)
      else GPutSprite(XRocket, YRocket, GRocketB2);
    end
	  else if (k and 4) > 0 then
      GPutSprite(XRocket, YRocket, GRocket1)
    else GPutSprite(XRocket, YRocket, GRocket2);
  end;
  if Retrace then
  begin
    if Damage = 40 then Dec(Power);
    if Damage <> 0 then Dec(Damage);
    Inc(PInt(@k)^);
  end;
end;

// check and draw gun
procedure TMainForm.Gun;
begin
  Shoot := Shoot or MainKey[VK_CONTROL];
  if (Shoot = 0) or (Power < 0) then Exit;
  if Retrace then
  begin
    if Shoot = 1 then
    begin
      Shoot := 2;
      XGun := XRocket + 10;
      YGun := YRocket + 14;
    end;
    Dec(YGun, 20);
    if YGun < -10 then Shoot := 0;
  end;
  GPutSprite(XGun, YGun, GMyGun);
  if YGun <> YRocket - 6 then GPutSprite(XGun, YGun + 10, GMyGun);
end;

// bomb enermy
procedure TMainForm.Toom;
var
  i: Integer;
begin
  i := 0;
  if not MainKey.PressOnce(VK_MENU) or (Bomb = 0) then Exit;
  if InsideInt(Enemy[0], 11, 13) then
  begin
    if HEnemy[0] <= 0 then Exit;
    Inc(i);
    Shoot := 0;
    if HEnemy[0] = 8 then
      HEnemy[0] := HEnemy[0] - 9
    else HEnemy[0] := HEnemy[0] - 8;
    WEnemy[0] := 40;
  end
  else EnemyDelay := 200;
  Dec(Bomb);
  while i < 20 do
  begin
    if Enemy[i] > 0 then Score := Score + EnemyScore[Enemy[i] - 1];
  	if (Enemy[i] = 4) or (Enemy[i] = 8) then
      Enemy[i] := 0
  	else if (Enemy[i] > 0) and (Enemy[i] <> 6) and (Enemy[i] <> 9) and (Enemy[i] <> 10) then
    begin
	    Enemy[i] := -10;
    end;
    Inc(i);
  end;
end;

function TMainForm.Hit(i: Integer): Boolean;
begin
// return 1 when gun hit sprite
  Result := (Shoot <> 0)
    and InsideInt(XGun, XEnemy[i] - 3, XEnemy[i] + 1 + EnemyBitmap[Enemy[i] - 1].Width)
    and InsideInt(YGun, YEnemy[i] - 20, YEnemy[i] + EnemyBitmap[Enemy[i] - 1].Height);
end;

function TMainForm.Beat(i: Integer): Boolean;
begin
// return 1 when rocket hit sprite
  Result := (Power >= 0)
    and InsideInt(XRocket + 10, XEnemy[i] - 6, XEnemy[i] + EnemyBitmap[Enemy[i] - 1].Width)
    and InsideInt(YRocket + 10, YEnemy[i] - 6, YEnemy[i] + EnemyBitmap[Enemy[i] - 1].Height);
end;

procedure TMainform.NewEnemy(i: Integer);
var
  j: Integer;
begin
  case Enemy[i] of
    1: // Killer
    begin
      XEnemy[i] := Random(XMax - 24);
    end;
    2: // Warper
    begin
	    XEnemy[i] := Random(XMax - 20);
      if XEnemy[i] < (XMax - 10) div 2 then
        WEnemy[i] := 2
      else WEnemy[i] := -2;
        HEnemy[i] := Random(190) + 30;
  	  end;
    3: //Bird
    begin
      XEnemy[i] := Random(XMax - 21);
      WEnemy[i] := 0;
      HEnemy[i] := Random(100) - 80;
  	end;
    4: // Ring
      begin
        EnemyDelay := 20;
        Enemy[i] := 0;
		  end;
    5: // Slam
    begin
  	  XEnemy[i] := Random(XMax - 24);
  	  WEnemy[i] := 0;
  	  HEnemy[i] := 2;
  	end;
    6: // Stone
    begin
		  XEnemy[i] := Random(XMax - 15);
		end;
    7: // Head
    begin
  	  XEnemy[i] := Random(XMax - 18);
  	  WEnemy[i] := 2;
    end;
		8: // Fire
    begin
  	  XEnemy[i] := Random(EnemyBitmap[Enemy[0] - 1].Width) + XEnemy[0];
  	  WEnemy[i] := Abs(XRocket - XEnemy[i]);
      HEnemy[i] := Abs(YRocket - YEnemy[i]);
  	  if (WEnemy[i] shr 1) = (HEnemy[i] shr 1) then
        WEnemy[i] := Random(3) + 1
  	  else if WEnemy[i] > HEnemy[i] then
  	    if WEnemy[i] > (HEnemy[i] shl 2) then
          WEnemy[i] := Random(3) + 2
    		else WEnemy[i] := Random(4) + 1
  	  else if HEnemy[i] > (WEnemy[i] shl 2) then
        WEnemy[i] := Random(2)
    	else WEnemy[i] := Random(3);
  	    HEnemy[i] := 4 - WEnemy[i];
		  if ((Random(2) <> 0) and (WEnemy[i] < 2)) or ((WEnemy[i] > 1) and (XRocket < XEnemy[i])) then
        WEnemy[i] := -WEnemy[i];
		  if YRocket < YEnemy[i] then HEnemy[i] := -HEnemy[i];
	  end;
    9, 10: // ItemB,ItemP
    begin
  	  XEnemy[i] := Random(XMax - 17);
    end;
		11, 12, 13: // Boss1, Boss2, Boss3
    begin
  	  for j := 0 to 19 do
      begin
        if (Enemy[j] <> 0) and (i <> j) then Break;
      end;
	    if j < 20 then
      begin
        Enemy[i] := 0;
        Dec(EnemyIndex);
        Exit;
      end;
		  if i <> 0 then
      begin
        Enemy[0] := Enemy[i];
        Enemy[i] := 0;
      end;
		  XEnemy[0] := 90;
		  YEnemy[0] := 10;
  	  WEnemy[0] := 0;
  	  HEnemy[0] := 60;
  	  KEnemy := 0;
	  end;
    14: // Boom1, Boom2, Boom3
    begin
  	  XEnemy[i] := Random(EnemyBitmap[Enemy[0] - 1].Width + 10) + XEnemy[0] - 15;
  	  YEnemy[i] := Random(EnemyBitmap[Enemy[0] - 1].Height + 10) + YEnemy[0] - 15;
  	  WEnemy[i] := 60;
    end;
  end;
end;

procedure TMainform.MoveEnemy(i: Integer);
var
  hurt, strike, dead: Boolean;
  j: Integer;
begin
  if Enemy[i] < 0 then
  begin
 	  Inc(YEnemy[i], 3);
    Inc(Enemy[i]);
  end
  else if Enemy[i] > 0 then
  begin
    dead := False;
    hurt := Beat(i);
    strike := Hit(i);
   	case Enemy[i] of
      6:
      begin
  	    if strike then Shoot := 0;
    	  if hurt then
        begin
          XRocket := XOld;
          YOld := YOld + 4;
          YRocket := YOld;
        end;
        Inc(YEnemy[i]);
      end;
      7:
      if (WEnemy[i] <> 0) and not hurt then
      begin
        if Random(100) = 0 then
        for j := 0 to 19 do if Enemy[j] = 0 then
        begin
     			Enemy[j] := 4;
     			XEnemy[j] := XEnemy[i] + 3;
     			YEnemy[j] := YEnemy[i] + 8;
     			if Abs(XRocket - XEnemy[j]) > Abs(YRocket - YEnemy[j]) then
          begin
     		    WEnemy[j] := 2;
            HEnemy[j] := 1;
     		  end
          else
          begin
            WEnemy[j] := 1;
            HEnemy[j] := 2;
          end;
     			if XRocket < XEnemy[j] then WEnemy[j] := -WEnemy[j];
     			if YRocket < YEnemy[j] then HEnemy[j] := -HEnemy[j];
     			Break;
   	    end;
   	    if strike then
        begin
          Dec(WEnemy[i]);
          Dec(YEnemy[i], 6);
          Shoot := 0;
        end;
        Inc(YEnemy[i]);
      end
      else dead := True;
      8:
      begin
        if (Damage = 0) and hurt then Damage := 40;
   	    XEnemy[i] := XEnemy[i] + WEnemy[i];
   	    YEnemy[i] := YEnemy[i] + HEnemy[i];
   	  end;
      9:
      begin
  	    if hurt then
        begin
          Enemy[i] := 0;
          Inc(Bomb);
        end;
        Inc(YEnemy[i]);
      end;
      10:
      begin
    	  if hurt and (Power < 11) then
        begin
       		Enemy[i] := 0;
          Power := Power + 4;
          if Power > 10 then Power := 10;
     	  end;
    	  Inc(YEnemy[i]);
      end;
      11, 12, 13:
      begin
        if (strike and (HEnemy[i] > 0)) or (HEnemy[i] < 0) then
        begin
       		Shoot := 0;
          if WEnemy[i] = 0 then
          begin
   		      WEnemy[i] := 40;
            if HEnemy[i] > 0 then
              HEnemy[i] := HEnemy[i] - 1
            else HEnemy[i] := 0;
            if HEnemy[i] = 0 then KEnemy := 500;
          end;
        end;
        if WEnemy[i] <> 0 then Dec(WEnemy[i]);
     	  if HEnemy[i] = 0 then
        begin
          Dec(KEnemy);
          if KEnemy < 100 then Inc(YEnemy[i]);
        end
    	  else
        begin
          if (Damage = 0) and hurt then Damage := 40;
       		case Enemy[i] of
         		12:
            begin
              if XEnemy[i] > XMax - 51 then
                KEnemy := 0
              else if XEnemy[i] < XMin then KEnemy := 1;
         			if KEnemy <> 0 then
                Inc(XEnemy[i])
              else Dec(XEnemy[i]);
            end;
       		  13:
            begin
              if XEnemy[i] > XMax - 54 then
              begin
                KEnemy := 1;
                Dec(XEnemy[i], 2);
              end
     		      else if YEnemy[i] > YMax - 79 then
              begin
                KEnemy := 2;
                Dec(YEnemy[i], 2);
              end
  		        else if XEnemy[i] < XMin then
              begin
                KEnemy := 3;
                Inc(XEnemy[i], 3);
              end
   	          else if YEnemy[i] < YMin then
              begin
                KEnemy := 0;
                Inc(YEnemy[i], 2);
              end;
              if KEnemy = 0 then
                Inc(XEnemy[i], 2)
              else if KEnemy = 2 then Dec(XEnemy[i], 3);
              if KEnemy = 1 then
                Inc(YEnemy[i], 2)
              else if KEnemy = 3 then Dec(YEnemy[i], 2);
     	    	end;
   	      end;
   	    end;
      end;
      14:
      begin
        Dec(WEnemy[i]);
  	    if WEnemy[i] <> 0 then
          Dec(YEnemy[i], 2)
    	  else
        begin
          Enemy[i] := 0;
          Exit;
        end;
      end;
    else
      if (Enemy[i] < 6) and not strike and not hurt then
      begin
        case Enemy[i] of
          1: Inc(YEnemy[i], 4);
      	  2:
          begin
            if YEnemy[i] > HEnemy[i] then
              XEnemy[i] := XEnemy[i] - WEnemy[i]
            else XEnemy[i] := XEnemy[i] + WEnemy[i];
            Inc(YEnemy[i], 3);
          end;
          3:
          begin
            if (WEnemy[i] = 0) and (YEnemy[i] > YRocket + HEnemy[i]) then
            begin
              WEnemy[i] := iif(XEnemy[i] > XRocket, -2, 2);
            end;
        	  XEnemy[i] := XEnemy[i] + WEnemy[i];
            if WEnemy[i] = 0 then
              Inc(YEnemy[i], 2)
            else Inc(YEnemy[i]);
          end;
          5:
          begin
            if Random(20) = 0 then
            begin
              if YRocket > YEnemy[i] then
                HEnemy[i] := 2
              else if YRocket < YEnemy[i] then
                HEnemy[i] := -2
              else HEnemy[i] := 0;
              if HEnemy[i] = 2 then
                WEnemy[i] := 0
              else if XRocket > XEnemy[i] then
                WEnemy[i] := 2
              else if XRocket < XEnemy[i] then
                WEnemy[i] := -2
              else WEnemy[i] := 0;
           		if (WEnemy[i] <> 0) and (HEnemy[i] = -2) then HEnemy[i] := -1;
            end;
        	  Inc(XEnemy[i], WEnemy[i]);
            Inc(YEnemy[i], HEnemy[i]);
          end;
        else
      	  Inc(XEnemy[i], WEnemy[i]);
          Inc(YEnemy[i], HEnemy[i]);
        end;
      end
      else dead := True;
    end;
    if dead then
    begin
      Inc(Score, EnemyScore[Enemy[i] - 1]);
      if (Damage = 0) and hurt then Damage := 40;
      if Enemy[i] = 4 then
        Enemy[i] := 0
      else Enemy[i] := -10;
      Shoot := 0;
    end;
  end;
end;

procedure TMainform.PutEnemySprite(i: Integer);
begin
  if Enemy[i] > 0 then
  begin
    if Enemy[i] < 11 then
      GPutSprite(XEnemy[i], YEnemy[i], GEnemySprite[Enemy[i] - 1])
    else case Enemy[i] of
      11, 12, 13:
      begin
     	  if (WEnemy[i] and 3) = 1 then
          GPutSprite(XEnemy[i], YEnemy[i], GEnemySpriteB[Enemy[i] - 1])
     	  else GPutSprite(XEnemy[i], YEnemy[i], GEnemySprite[Enemy[i] - 1]);
      end;
      14:
      begin
        if WEnemy[i] > 30 then
          GPutSprite(XEnemy[i], YEnemy[i], GEnemySprite[13])
        else if WEnemy[i] > 10 then
          GPutSprite(XEnemy[i], YEnemy[i], GEnemySprite[14])
        else GPutSprite(XEnemy[i], YEnemy[i], GEnemySprite[15]);
      end;
    end;
  end
  else if Enemy[i] < 0 then
  begin
  	if Enemy[i] < -4 then
      GPutSprite(XEnemy[i], YEnemy[i], GEnemySprite[13])
  	else if Enemy[i] < -2 then
      GPutSprite(XEnemy[i] + 2, YEnemy[i], GEnemySprite[14])
    else GPutSprite(XEnemy[i] + 4, YEnemy[i], GEnemySprite[15]);
  end;
end;

// return True when stage clear
function TMainForm.PutEnemy: Boolean;
var
  i, j: Integer;
begin
  Result := False;
  for i := 0 to 19 do
  begin
    if Enemy[i] > 0 then
    begin
    	if OutsideInt(YEnemy[i], -50, 239) or OutsideInt(XEnemy[i], -50, 359) then
      begin
  	    if OutsideInt(Enemy[i], 11, 13) then
        begin
          Enemy[i] := 0;
          Continue;
        end
  	    else
        begin
          for j := 1 to 19 do if Enemy[j] <> 0 then Break;
      		if j = 20 then
          begin
	    	    Score := Score + EnemyScore[Enemy[i] - 1];
            Result := Life > 0;
            Exit;
          end;
        end;
      end;
    end;
    PutEnemySprite(i);
    if Retrace then MoveEnemy(i);
  end;
  if not Retrace then Exit;
  if EnemyDelay <> 0 then
    Dec(EnemyDelay)
  else
  begin
    for i := 0 to 19 do
	  if Enemy[i] = 0 then
    begin
      if Enemy[0] >= 11 then
        if YEnemy[0] < 240 then
          if HEnemy[0] <> 0 then
            Enemy[i] := 8
          else Enemy[i] := 14
        else Enemy[i] := 0
      else
      begin
        Enemy[i] := EnemyMap[EnemyIndex];
        Inc(EnemyIndex);
      end;
		  if Stage = 2 then case Enemy[i] of
		    1: Enemy[i] := 2;
		    2: Enemy[i] := 3;
		    3: Enemy[i] := 7;
		    11: Enemy[i] := 12;
		  end
      else if Stage = 3 then case Enemy[i] of
		    1: Enemy[i] := 3;
		    2: Enemy[i] := 7;
		    3: Enemy[i] := 5;
		    11: Enemy[i] := 13;
  		end;
      if Enemy[0] >= 11 then
        YEnemy[i] := Random(50) + YEnemy[0]
      else YEnemy[i] := -EnemyBitmap[Enemy[i] - 1].Height;
      NewEnemy(i);
  		Break;
    end;
    if i = 20 then
      EnemyDelay := 0
    else if Enemy[i] = 7 then
      EnemyDelay := Random(70)
    else if (Enemy[i] = 6) or InsideInt(Enemy[0], 11, 13) then
      EnemyDelay := Random(20)
    else EnemyDelay := Random(50);
  end;
end;

// state clear return True when ready
function TMainForm.PassGame: Boolean;
begin
  if Retrace then Dec(PassDelay);
  if PassDelay <> 0 then
  begin
    PutText(50, 90, Format('เย้! ผ่านฉาก %d แล้ว', [Stage]), Color32($FF30CB00));
    Result := False;
  end
  else
  begin
    PassDelay := 200;
    Inc(Stage);
    Inc(Life);
    Enemy[0] := 0;
    Result := True;
  end;
end;

procedure TMainForm.GPutSprite(px, py: Integer; tex: TXPTexture);
begin
  tex.BlendSrc := GL_SRC_ALPHA;
  tex.Draw(ScaleRect(px, py, tex.Width, tex.Height));
end;

procedure TMainForm.PutText(px, py: Integer; AText: string; c32: TColor32);
var
  w, h: Integer;
  c: TGLRGBAFloat;
  s: AnsiString;
begin
  s := AnsiString(AText);
  w := MainFont.TextWidth(s);
  h := MainFont.TextHeight(s);
  c.R := c32.R / 255;
  c.G := c32.G / 255;
  c.B := c32.B / 255;
  c.A := 1.0;
  MainFont.ColorFloat := c;
  MainFont.GLTextOut(ScaleRect(px, py, w, h), AText);
end;

procedure TMainForm.PutNumber(px, py: Integer; ANumber: Int64; c32: TColor32; digit: Integer = 0);
var
  s: string;
begin
  if digit > 0 then
    s := Format('%%%d.%dd', [digit, digit])
  else s := '%d';
  s := Format(s, [ANumber]);
  PutText(px, py, s, c32);
end;

function TMainForm.ScaleX(px: Integer): Integer;
begin
  Result := px * MainGL.Width div XScreen;
end;

function TMainForm.ScaleY(py: Integer): Integer;
begin
  Result := py * MainGL.Height div YScreen;
end;

function TMainForm.ScaleRect(px, py, nx, ny: Integer): TRect;
begin
  Result := Rect(ScaleX(px), ScaleY(py), ScaleX(px + nx), ScaleY(py + ny));
end;

end.
